# Copy this file to .env.local and fill in the values
# All variables are validated at boot by src/lib/env.ts

# ─── Database ────────────────────────────────────────────────────────────────
# Neon Postgres — region eu-central-1 (Frankfurt)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ─── Auth.js v5 ──────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# ─── Magic links ─────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
MAGIC_LINK_SECRET=

# ─── Brevo (transactional emails) ─────────────────────────────────────────────
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@open.pf
BREVO_SENDER_NAME=OPEN PF

# ─── Cron protection ─────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
CRON_SECRET=

# ─── File storage (Vercel Blob) ───────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ─── Analytics & monitoring ──────────────────────────────────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=open.pf
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_NOTIFICATION_EMAIL=bureau@open.pf
